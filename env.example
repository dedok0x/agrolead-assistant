TZ=Europe/Moscow
DATABASE_URL=postgresql+psycopg://agrolead:agrolead123@db:5432/agrolead
POSTGRES_DB=agrolead
POSTGRES_USER=agrolead
POSTGRES_PASSWORD=agrolead123

MODEL_NAME=qwen2.5:0.5b
OLLAMA_BASE=http://ollama:11434
MODEL_NUM_CTX=8192
MODEL_NUM_PREDICT=180
LLM_PROVIDER=auto

# GigaChat (опционально). Если заполнен GIGACHAT_AUTH_KEY, в режиме auto он используется
# как основной провайдер, а Ollama становится fallback.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://gigachat.devices.sberbank.ru/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_SSL=1
GIGACHAT_TOKEN_REFRESH_SECONDS=1500
LLM_REQUEST_TIMEOUT_SECONDS=45

PICOCLAW_IMAGE=ghcr.io/sipeed/picoclaw:latest
PICOCLAW_LOG_LEVEL=info

ADMIN_USER=admin
ADMIN_PASS=315920
ADMIN_TOKEN=agrolead-admin-token

