# --- Core ---
TZ=Europe/Moscow

# --- Database ---
POSTGRES_DB=agrolead
POSTGRES_USER=agrolead
POSTGRES_PASSWORD=agrolead123
DATABASE_URL=postgresql+psycopg://agrolead:agrolead123@db:5432/agrolead

# --- Admin panel ---
ADMIN_USER=admin
ADMIN_PASS=315920
ADMIN_TOKEN=
ALLOW_STATIC_ADMIN_TOKEN=0
ADMIN_SESSION_TTL_MINUTES=720
RESET_ADMIN_PASSWORD_ON_STARTUP=0

# --- Dialogue behavior ---
SALES_STYLE=kuban-direct
TOXIC_STRICT_MODE=1

# --- LLM router ---
LLM_PROVIDER=gigachat
LLM_REQUEST_TIMEOUT_SECONDS=5
LLM_MAX_RETRIES=1
LLM_REWRITE_ENABLED=1

# --- GigaChat ---
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_VERIFY_SSL=1
GIGACHAT_CA_FILE=
GIGACHAT_INSECURE_SSL_FALLBACK=0
